#!/usr/bin/env groovy

pipeline{
    agent any
    stages{
        stage('Build'){
            steps{
                echo 'Building App'
            }
        }
        stage('Test'){
            steps{
                echo 'Running Test'
            }
        }
      stage('Deploy'){
            steps{
                echo 'Deploying app'
            }
        }
    }
}
